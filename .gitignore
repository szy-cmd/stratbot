# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example
!.env.*.example

# Node
node_modules/
dist/
.vite/

# Data & artifacts (too large for git)
backend/data/fastf1_cache/
backend/data/raw/
backend/data/processed/
backend/data/output/
backend/data/models/*.pkl
backend/data/models/*.joblib
backend/data/models/*.cbm
backend/data/models/*.ubj
*.parquet
*.csv
*.7z
*.zip

# ML run output
catboost_info/
lightning_logs/
checkpoints/
*.ckpt
*.png
!docs/evaluation/**/*.png

# IDE / local tooling
.idea/
.vscode/
*.swp
.aider*
.cursor/
terminals/

# OS
Thumbs.db
.DS_Store
desktop.ini

# Logs
*.log
errors.log
progress.json

# Large source 3D model assets (only the runtime copy required by the car customizer
# in frontend/public/models/f1_2025_mclaren_mcl39/ should be committed; the root
# "3d models/" dump with .glb/.usdz and duplicate data is unnecessary bloat)
3d models/

# Allow the detailed PBR textures for the F1 car model (the CarCustomizer loads
# the glTF which references these; the global *.png ignore is for ML artifacts)
!frontend/public/models/**/*.png
!frontend/public/models/**/*.jpg