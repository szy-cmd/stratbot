# StratBot Backend Environment Configuration
# Copy this to .env (gitignored) and customize.
# All data paths are restricted to the J: drive per project setup.

# Path to the primary training/eval dataset (produced by the pipeline into parquet-output folder)
# This is the canonical location from our F1 work: contains f1_model_ready_2018_2025.parquet + evaluation images
STRATBOT_DATASET=J:\F1\f1_cache\parquet-output\f1_model_ready_2018_2025.parquet

# Optional: override other paths if needed (see config.py)
# STRATBOT_BACKEND_ROOT=...

# For frontend dev (in frontend/ .env or .env.local):
# VITE_API_BASE=http://127.0.0.1:5000
