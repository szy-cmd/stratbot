# StratBot Backend Environment Configuration
# Copy this to backend/.env (gitignored) and customize.
#
# For friends / other machines with your own downloaded F1 data:
# 1. Put your f1_model_ready_2018_2025.parquet (and the rest of parquet-output if you want the graphs)
#    anywhere convenient, e.g. C:\F1Data\parquet-output\
# 2. Set STRATBOT_DATASET below to the FULL path of the parquet file.
# 3. (Optional) Also copy the .joblib model into backend/data/models/ or retrain.

# Path to the primary training/eval dataset
STRATBOT_DATASET=C:\Path\To\Your\F1Data\parquet-output\f1_model_ready_2018_2025.parquet

# Optional: override other paths if needed (see config.py)
# STRATBOT_BACKEND_ROOT=...

# For frontend dev (create frontend/.env or .env.local):
# VITE_API_BASE=http://127.0.0.1:5000
